# Cell 1 — Setup
import sys; sys.path.insert(0, "..")
import pandas as pd
import duckdb
import plotly.io as pio
pio.renderers.default = "notebook"

from src.ingestion import load_and_clean
from src.profiling import generate_quality_report, field_completeness
from src.schema import build_all_tables, save_to_duckdb
from src.analysis import *
from src.visualization import *

# Cell 2 — Load
df = load_and_clean("../data/raw/oncology_trials.csv")
print(df.shape)
df.head(3)

# Cell 3 — Quality report
report = generate_quality_report(df)
comp = field_completeness(df)
comp.style.background_gradient(subset=["completeness_%"], cmap="RdYlGn")

# Cell 4 — Schema + DB
tables = build_all_tables(df)
conn = save_to_duckdb(tables, "../data/processed/oncology.duckdb")

# Cell 5 — Overall summary
summary = overall_summary(conn)
pd.Series(summary).to_frame("value")

# Cell 6 — Phase success
phase_df = phase_success(conn)
fig_phase_success(phase_df).show()

# Cell 7 — Technology heatmap
tph_df = technology_phase_success(conn)
fig_technology_heatmap(tph_df).show()

# Cell 8 — Indication bars
ind_df = indication_phase_success(conn)
ind_agg = (ind_df.groupby("indication", as_index=False)
           .agg({"completion_rate":"mean","n_evaluable":"sum",
                 "ci_lower":"min","ci_upper":"max","suppressed":"any"}))
fig_indication_bars(ind_agg).show()

# Cell 9 — Temporal trend
trend_df = phase_year_trend(conn)
fig_temporal_trend(trend_df).show()

# Cell 10 — Key insight tables
print("\n=== Phase Success Rates ===")
display(phase_df[["phase_label","n_evaluable","completion_rate","ci_lower","ci_upper","suppressed"]])

print("\n=== Technology Group Success Rates ===")
tech_df = technology_success(conn)
display(tech_df[["technology_group","n_evaluable","completion_rate","ci_lower","ci_upper"]])
